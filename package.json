{
  "name": "alexa-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-with-system-ca.mjs",
    "dev:bg": "node scripts/dev-process.mjs start",
    "dev:plain": "node --import tsx src/server.ts",
    "status": "node scripts/dev-process.mjs status",
    "stop": "node scripts/dev-process.mjs stop",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ask-sdk-core": "^2.14.0",
    "ask-sdk-express-adapter": "^2.14.0",
    "ask-sdk-model": "^1.86.0",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "openai": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
